rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          (request.auth.token.keys().hasAny(['admin']) && request.auth.token.admin == true)
          || request.auth.token.email == 'gabrielvieiraxc12@gmail.com'
        );
    }

    function ownsIncomingData() {
      return signedIn()
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /cronograma/{weekId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /shared_library/{itemId} {
      allow read: if isAdmin() || (signedIn() && resource.data.published == true);
      allow write: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if isAdmin()
          || (
            signedIn()
            && get(/databases/$(database)/documents/shared_library/$(itemId)).data.published == true
          );
        allow write: if isAdmin();
      }
    }

    match /access_logs/{logId} {
      allow create, update: if ownsIncomingData() || isAdmin();
      allow read, delete: if isAdmin();
    }

    match /user_devices/{deviceId} {
      allow create, update: if ownsIncomingData() || isAdmin();
      allow read, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
