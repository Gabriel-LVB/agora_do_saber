{
  "name": "vite-react-starter",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run test:unit && npm run build && npm run budget",
    "audit:moderate": "npm audit --audit-level=moderate",
    "budget": "node --no-warnings scripts/build-budget.mjs",
    "test:preflight": "npm run check",
    "test:unit": "node --no-warnings scripts/unit-smoke.mjs",
    "ux:smoke": "node scripts/ux-smoke.mjs"
  },
  "dependencies": {
    "firebase": "^12.12.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "playwright": "^1.60.0",
    "postcss": "^8.3.11",
    "tailwindcss": "^2.2.19",
    "vite": "^8.1.2"
  }
}
