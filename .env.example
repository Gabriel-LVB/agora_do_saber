# Use somente as credenciais do projeto Firebase isolado da Ágora 2.0.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Identifica visualmente e nos logs o ambiente privado.
VITE_APP_ENV=agora-2-dev

# Recursos incompletos devem permanecer desligados.
VITE_FEATURE_TODAY_HOME=false
VITE_FEATURE_GLOBAL_SEARCH=false
VITE_FEATURE_NEW_NAVIGATION=false
VITE_FEATURE_LOCAL_GEMINI_KEYS=false
